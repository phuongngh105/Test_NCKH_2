<?xml version="1.0" encoding="UTF-8"?>

<!-- SUMO config used by the GA runner -->

<sumoConfiguration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/sumoConfiguration.xsd">

    <input>
        <net-file value="ngatu.net.xml"/>
        <route-files value="ngatu.net.rou.xml"/>
        <additional-files value="thongke.xml"/>
    </input>

    <time>
        <begin value="0"/>
        <end value="3600"/>
    </time>

</sumoConfiguration>
